<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include layout="@layout/include_title" />

    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="10dp">

        <LinearLayout
            android:id="@+id/linearLayout35"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:hint="@string/edit_hint1"
                android:textColorHint="#FF0000">

                <AutoCompleteTextView
                    android:id="@+id/projectname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:textColor="#000000" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:hint="@string/edit_hint2"
                android:textColorHint="#FF0000">

                <AutoCompleteTextView
                    android:id="@+id/sample_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/textInputLayout"
                    android:layout_alignStart="@+id/textInputLayout"
                    android:maxLines="1"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:hint="@string/edit_hint3"
                android:textColorHint="#FF0000">

                <AutoCompleteTextView
                    android:id="@+id/sample_type_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/textInputLayout"
                    android:layout_alignStart="@+id/textInputLayout"
                    android:maxLines="1"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:hint="@string/edit_hint4"
                android:textColorHint="#FF0000">

                <AutoCompleteTextView
                    android:id="@+id/samplename"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/textInputLayout"
                    android:layout_alignStart="@+id/textInputLayout"
                    android:maxLines="1"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:hint="@string/edit_hint5"
                android:textColorHint="#FF0000">

                <AutoCompleteTextView
                    android:id="@+id/samplenum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/textInputLayout"
                    android:layout_alignStart="@+id/textInputLayout"
                    android:maxLines="1"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:hint="@string/edit_hint6"
                android:textColorHint="#FF0000">

                <AutoCompleteTextView
                    android:id="@+id/standnum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/textInputLayout"
                    android:layout_alignStart="@+id/textInputLayout"
                    android:maxLines="1"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>


            <LinearLayout
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/edit_hint7"
                    android:textColor="#FF0000"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/Demarcate"
                    android:layout_width="300dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/background_item_gray"
                    android:gravity="center"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="#000000" />
            </LinearLayout>


            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:hint="@string/edit_hint8"
                android:textColorHint="#FF0000">

                <AutoCompleteTextView
                    android:id="@+id/StandarValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/textInputLayout"
                    android:layout_alignStart="@+id/textInputLayout"
                    android:inputType="numberDecimal"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="400dp"
                android:layout_height="wrap_content"
                android:hint="@string/edit_hint9"
                android:textColorHint="#FF0000">

                <AutoCompleteTextView
                    android:id="@+id/Unit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:layout_below="@+id/textInputLayout"
                    android:layout_alignStart="@+id/textInputLayout"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_cancle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/btn_bottom_confirm_bg"
                    android:text="@string/cancel"
                    android:textColor="#DC000F"
                    android:textSize="18dp"
                    android:visibility="visible" />

                <Button
                    android:id="@+id/btn_determine"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="20dp"
                    android:background="@drawable/btn_bottom_confirm_bg"
                    android:text="@string/sure"
                    android:textColor="#fff"
                    android:textSize="18dp"
                    android:visibility="visible" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>