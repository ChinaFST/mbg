<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:layout_margin="5dp"
    android:gravity="center"
    app:cardBackgroundColor="@color/tm55"
    app:cardCornerRadius="2dp"
    app:cardElevation="1dp"
    app:cardPreventCornerOverlap="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/itemtype"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:text=""
                android:textColor="#B2B1B1"
                android:textSize="16sp"
                android:textStyle="italic"
                android:visibility="gone" />

            <TextView
                android:id="@+id/version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="6dp"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="14sp"
                android:gravity="center"
                android:maxLines="2"
                android:text="农药残留农药残留农药残留"
                android:textColor="#1a1a1a"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textView45"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/title"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="12dp"
                android:text="@string/test_method_colon"
                android:textColor="#333333"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/editText20"
                android:layout_width="114sp"
                android:layout_height="wrap_content"
                android:layout_alignBaseline="@+id/textView45"
                android:layout_alignBottom="@+id/textView45"
                android:layout_toRightOf="@+id/textView45"
                android:textColor="#474747"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/editText20"
                android:layout_marginTop="36dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="10dp">

                <Button
                    android:id="@+id/edtor_item"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_bottom_confirm_bg"
                    android:text="@string/editor"
                    android:textColor="#ffffff"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/delete_item"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_bottom_confirm_bg"
                    android:text="@string/delete"
                    android:textColor="#FF0000"
                    android:textSize="14sp" />
            </LinearLayout>
        </RelativeLayout>


    </LinearLayout>


</androidx.cardview.widget.CardView>



